# ── RecruitAI Backend Configuration ──────────────

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secret (generate a random string: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Lemon Squeezy (https://app.lemonsqueezy.com → Settings → API)
# Only needed to verify webhooks. Lemon Squeezy handles all billing,
# checkout, taxes, and subscription management for you.
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# Your Lemon Squeezy "Buy Now" checkout link for the Pro plan
LEMONSQUEEZY_CHECKOUT_URL=https://yourstore.lemonsqueezy.com/buy/xxxxxxxx

# Anthropic API key — powers all AI generation for every user.
# This lives ONLY on the server, never in the extension. You pay for
# usage here; subscriptions and daily limits cover the cost.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database path
DB_PATH=./data/recruitai.db
